#!/usr/bin/env bash
# box — Apple Container でエージェント(Claude Code / Codex)を隔離して放牧する
#
# 使い方:
#   box                              → カレントのプロジェクトで claude を対話起動
#   box <プロジェクトのパス>           → 指定したプロジェクトで claude を対話起動
#   box <プロジェクトのパス> bash      → 箱の中の shell に入る(コマンド指定時はパス必須。例: box . bash)
#   box <プロジェクトのパス> codex     → 箱の中で codex を起動
#   box <プロジェクトのパス> <コマンド> → 箱の中で任意コマンドを実行
#   box update                       → イメージを最新化(claude/codex を再ビルド。手動更新)
#
# 箱の中:
#   - /work にプロジェクトをマウント(編集はホストに反映)
#   - 認証は ~/.config/agent-box/claude のコピーをマウント(サブスクのまま・ホスト本体は触らない)
#   - codex 認証は ~/.config/agent-box/codex(auth.json のみ)のコピーをマウント(host の重い config は持ち込まない)
#   - ~/.gitconfig を読み取り専用でマウント(commit 用の identity)
#   - 任意の Claude plugin(自前の skill+hooks 等)を持ち込める(既定の置き場は ~/.config/agent-box/plugin。無ければ素の claude)
#   - plugin に skills/ があれば codex にも渡す(/home/dev/.codex/skills に ro マウント。codex 側は skill のみ=hooks/floors は付かない)
#   - 箱内 git push は gh トークン(~/.config/agent-box/gh-token)を使った HTTPS で通す(ssh 鍵は箱に渡さない)
#   - gh トークンは GH_TOKEN でも渡す(PR作成・gh API 用)
#
# セキュリティ上の割り切りは README「セキュリティ / 隔離の実力」を参照。
set -euo pipefail

# --- このスクリプト自身の場所から repo ルートを求める ---------------------------
# box は Homebrew の symlink(/opt/homebrew/bin/box)から起動されるため、symlink を
# 解決してから dirname を取る。box update の再ビルドコンテキストがこの値に依存する。
_src="${BASH_SOURCE[0]}"
while [ -L "$_src" ]; do
  _link="$(readlink "$_src")"
  case "$_link" in
    /*) _src="$_link" ;;                     # 絶対 symlink
    *)  _src="$(dirname "$_src")/$_link" ;;  # 相対 symlink
  esac
done
BOX_DIR="$(cd "$(dirname "$_src")" && pwd)"

IMAGE=agent-sandbox   # 焼き込みイメージのタグ(名前は1箇所に集約)
STALE_DAYS=14         # これより古いイメージなら起動時にヒントを出す(自動更新はしない)

# box update → イメージを最新化(claude/codex/gh を最新に焼き直す)。
# 自動更新はあえてしない(再現性・起動速度・オフライン性のため)。更新したい時だけ手動で。
if [ "${1:-}" = "update" ]; then
  echo "[box] イメージ再ビルド中(claude/codex を最新化、数分かかります)…" >&2
  # uid はホストの実 uid に合わせて焼く(macOS の 501 以外でもマウントを読み書き可)。
  # AGENT_BOX_APT_EXTRA があれば追加 apt パッケージとして焼く(例: AGENT_BOX_APT_EXTRA="ripgrep vim")。
  exec container build --no-cache \
    --build-arg "HOST_UID=$(id -u)" \
    --build-arg "APT_EXTRA=${AGENT_BOX_APT_EXTRA:-}" \
    -t "$IMAGE" "$BOX_DIR"
fi

PROJECT="${1:-$PWD}"
if [ ! -d "$PROJECT" ]; then
  echo "error: プロジェクトのパスが見つかりません: $PROJECT" >&2
  exit 1
fi
PROJECT="$(cd "$PROJECT" && pwd)"   # 絶対パス化
shift || true

# 設定パスは env で上書き可(未指定なら XDG の ~/.config/agent-box 配下が既定)。個人の配置に縛られない汎用既定。
# 個人化(plugin を常用する等)は shell の profile に export AGENT_BOX_* を書けばよい。
_cfg_base="${XDG_CONFIG_HOME:-$HOME/.config}/agent-box"
CLAUDE_CFG="${AGENT_BOX_CLAUDE_CFG:-$_cfg_base/claude}"      # Claude 認証(host ~/.claude のコピー)。必須
CODEX_CFG="${AGENT_BOX_CODEX_CFG:-$_cfg_base/codex}"         # codex 認証(auth.json)の curated コピー。任意
GH_TOKEN_FILE="${AGENT_BOX_GH_TOKEN:-$_cfg_base/gh-token}"   # 箱用 gh トークン(repo 外・chmod600)。push / PR作成 / gh API 用。任意
# plugin(skill+hooks)の既定は「設定ディレクトリ下の plugin」。そこに置くか symlink すれば常時 ON、
# 無ければ素の claude。AGENT_BOX_PLUGIN_DIR=<path> で明示、AGENT_BOX_PLUGIN_DIR=(空)で強制 OFF。
PLUGIN_DIR="${AGENT_BOX_PLUGIN_DIR-$_cfg_base/plugin}"
[ -n "$PLUGIN_DIR" ] && [ -d "$PLUGIN_DIR" ] && PLUGIN_DIR="$(cd "$PLUGIN_DIR" && pwd -P)"  # symlink を実体に解決(mount 元を確定)

# Claude 認証は必須。無ければ「未認証 claude が黙って起動」する曖昧な失敗にせず、明確に落とす。
[ -d "$CLAUDE_CFG" ] || {
  echo "error: Claude 認証が未設定です: $CLAUDE_CFG" >&2
  echo "       README「セットアップ」を参照(host ~/.claude を curated コピー)。" >&2
  exit 1
}

MOUNTS=(-v "$PROJECT:/work" -v "$CLAUDE_CFG:/home/dev/.claude")
[ -f "$HOME/.gitconfig" ] && MOUNTS+=(-v "$HOME/.gitconfig:/home/dev/.gitconfig:ro")
[ -d "$CODEX_CFG" ] && MOUNTS+=(-v "$CODEX_CFG:/home/dev/.codex")
[ -n "$PLUGIN_DIR" ] && [ -d "$PLUGIN_DIR" ] && MOUNTS+=(-v "$PLUGIN_DIR:/opt/plugin:ro")
# plugin に skills/ があれば codex にも渡す(codex は ~/.codex/skills を読む=箱では /home/dev/.codex/skills)。
# 既存の .codex マウントの中へ入れ子で ro 追加(auth.json と共存。codex 側は skill のみ・hooks は付かない)。
[ -d "$CODEX_CFG" ] && [ -n "$PLUGIN_DIR" ] && [ -d "$PLUGIN_DIR/skills" ] && MOUNTS+=(-v "$PLUGIN_DIR/skills:/home/dev/.codex/skills:ro")

# gh トークンがあれば注入。push はここから供給する HTTPS 認証で通す(ssh 鍵は箱に渡さない=箱が触れる鍵を
# 「host の ssh 鍵ぜんぶ」から「GitHub 用の最小 PAT だけ」に縮小する)。
#   - GH_TOKEN     : PR作成 / gh API 用
#   - GIT_CONFIG_* : git@github.com: / https://github.com/ を token 埋め込み HTTPS に書き換え(insteadOf)。
#                    ro マウントの ~/.gitconfig を汚さないよう env で注入(ファイル書き込み不要)。
#   ※token が launch 時に host の ps へ一瞬見える点は単一ユーザ Mac として許容(GH_TOKEN と同じ扱い)。
if [ -f "$GH_TOKEN_FILE" ]; then
  _ght="$(cat "$GH_TOKEN_FILE")"
  _tokurl="https://x-access-token:${_ght}@github.com/"
  MOUNTS+=(
    -e "GH_TOKEN=$_ght"
    -e "GIT_CONFIG_COUNT=2"
    -e "GIT_CONFIG_KEY_0=url.${_tokurl}.insteadOf" -e "GIT_CONFIG_VALUE_0=git@github.com:"
    -e "GIT_CONFIG_KEY_1=url.${_tokurl}.insteadOf" -e "GIT_CONFIG_VALUE_1=https://github.com/"
  )
else
  echo "[box] gh トークン未設定($GH_TOKEN_FILE): 箱内 git push / gh は無効です(README の gh 設定を参照)。" >&2
fi

# イメージ未ビルドなら、container の低レベルエラーで面食らわせず更新方法を示して止める
# (別Mac の clone 直後、box update を踏む前にここへ来やすい。box update は上で exec 済みなので影響しない)
container image inspect "$IMAGE" >/dev/null 2>&1 || {
  echo "error: イメージ '$IMAGE' が未ビルドです。まず: box update" >&2
  echo "       (初回ビルドは数分。README「セットアップ」参照)" >&2
  exit 1
}

# イメージが古ければ軽く知らせるだけ(自動更新はしない。取得/解析失敗時は黙ってスキップ)
_created=$(container image inspect "$IMAGE" 2>/dev/null | grep -m1 '"creationDate"' | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' || true)
if [ -n "${_created:-}" ]; then
  _c=$(date -j -f "%Y-%m-%d" "$_created" +%s 2>/dev/null || echo 0)
  if [ "$_c" -gt 0 ]; then
    _age=$(( ( $(date +%s) - _c ) / 86400 ))
    if [ "$_age" -ge "$STALE_DAYS" ]; then
      echo "[box] イメージは ${_age}日前 のビルドです。最新化は: box update" >&2
    fi
  fi
fi

# 共通の起動コマンド(resource limit 等を足すならこの1箇所に)。
RUN=(container run --rm -it "${MOUNTS[@]}" -w /work "$IMAGE")

if [ "$#" -gt 0 ]; then
  exec "${RUN[@]}" "$@"
elif [ -n "$PLUGIN_DIR" ] && [ -d "$PLUGIN_DIR" ]; then
  # 持ち込み plugin を直読み(skill + hooks=floors も同時に入る)
  echo "[box] plugin: $PLUGIN_DIR を読み込みます" >&2
  exec "${RUN[@]}" claude --dangerously-skip-permissions --plugin-dir /opt/plugin
else
  echo "[box] plugin: なし(AGENT_BOX_PLUGIN_DIR で Claude plugin を指定可)" >&2
  exec "${RUN[@]}" claude --dangerously-skip-permissions
fi
